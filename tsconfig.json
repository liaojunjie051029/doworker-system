{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "target": "ES2021",
    "lib": ["ES2021"],
    "types": ["node"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": false,
    "sourceMap": false,
    "declaration": false
  },
  "include": ["src/**/*"]
}